# Copy to contracts/.env — never commit.
# Deployer private key for Foundry broadcasts (Celo Sepolia for G15/G16).

DEPLOYER_PRIVATE_KEY=
TREASURY_ADDRESS=

# Celo Sepolia (testnet) — G15 Boast + G16 TournamentVault (Alfajores 44787 sunset Sep 2025)
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# Official Sepolia USDm (Mento Dollar — player label "cUSD")
CUSD_TOKEN_ADDRESS=0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b

# Optional Mainnet (do not use for G15/G16 vault unless funded + audited)
# CELO_MAINNET_RPC_URL=https://forno.celo.org
# CUSD_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# Optional explorer verify
CELOSCAN_API_KEY=
