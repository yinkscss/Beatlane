# Copy to .env in this directory. Never commit .env.
# Magic publishable key only — never commit secrets or deployer keys.

# Auth (Magic.link)
VITE_MAGIC_PUBLISHABLE_KEY=

# Supabase (project: blockblast)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Observability (wire at G18)
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Celo (Mainnet — chain id 42220)
VITE_CELO_RPC_URL=https://forno.celo.org
VITE_CELO_CHAIN_ID=42220
VITE_CUSD_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
# Receiver for Second Chance / helpers / shop payments (your Celo Mainnet wallet)
VITE_TREASURY_ADDRESS=

# G15 Boast attestation — Celo Sepolia (testnet; Alfajores sunset). Continues stay Mainnet (Q07).
# Deploy: see contracts/README.md — paste address after forge script broadcast.
VITE_BOAST_CONTRACT_ADDRESS=
VITE_BOAST_CHAIN_ID=11142220
VITE_BOAST_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
VITE_BOAST_CUSD_ADDRESS=0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b
# Optional: Sepolia treasury (defaults to on-chain constructor treasury)
# VITE_BOAST_TREASURY_ADDRESS=

# G16 Blitz tournaments — entry fees use Mainnet VITE_TREASURY_ADDRESS (Q07).
# Optional cup vault on Celo Sepolia (escrow/payout stub). Alfajores sunset.
VITE_TOURNAMENT_CONTRACT_ADDRESS=
VITE_TOURNAMENT_CHAIN_ID=11142220
VITE_TOURNAMENT_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# G13 Upstash: set as Supabase Edge secrets (not VITE_). See root .env.example.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

