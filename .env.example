# Copy to apps/web/.env (Vite loads from the web app cwd). Never commit .env.
# Magic publishable key only — never commit secrets or deployer keys.

# Auth (Magic.link)
VITE_MAGIC_PUBLISHABLE_KEY=

# Supabase (project: blockblast)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Observability (G18) — placeholders only; never commit real DSNs/keys.
# Human create steps: README → "G18 Observability".
VITE_SENTRY_DSN=
# Project API key (phc_…) — NOT a personal API key (phx_…)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Optional local setup only (never VITE_, never commit):
# POSTHOG_PERSONAL_API_KEY=
# Edge error capture (Supabase secret — not VITE_):
#   supabase secrets set SENTRY_DSN=https://…@….ingest.sentry.io/… --project-ref zxtwshhlicditrvqafzo
# SENTRY_DSN=

# Celo (Mainnet — chain id 42220)
VITE_CELO_RPC_URL=https://forno.celo.org
VITE_CELO_CHAIN_ID=42220
VITE_CUSD_TOKEN_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
# Receiver for Second Chance / shop payments (your Celo Mainnet wallet)
VITE_TREASURY_ADDRESS=

# ---------------------------------------------------------------------------
# G15 Boast (Celo Sepolia testnet; Alfajores sunset) — separate from Mainnet continues (Q07)
# Deploy from contracts/ then paste address. Never commit deployer keys.
# VITE_BOAST_CONTRACT_ADDRESS=
# VITE_BOAST_CHAIN_ID=11142220
# VITE_BOAST_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# VITE_BOAST_CUSD_ADDRESS=0xdE9e4C3ce781b4bA68120d6261cbad65ce0aB00b

# ---------------------------------------------------------------------------
# G16 Blitz tournaments — entry fees stay Mainnet (VITE_TREASURY_ADDRESS).
# Optional TournamentVault on Celo Sepolia (escrow/payout stub). Never commit deployer keys.
# VITE_TOURNAMENT_CONTRACT_ADDRESS=
# VITE_TOURNAMENT_CHAIN_ID=11142220
# VITE_TOURNAMENT_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# ---------------------------------------------------------------------------
# G17 Season Pass — $2.99 cUSD Mainnet (VITE_TREASURY_ADDRESS). Staging = same Mainnet path.
# Optional Edge cron: supabase secrets set SEASON_PASS_CRON_SECRET=...
# SEASON_PASS_CRON_SECRET=

# ---------------------------------------------------------------------------
# G13 Upstash Redis (Edge Function secrets — NOT Vite / NOT committed)
# Create free DB: https://console.upstash.com/ → Redis → Create Database
# Then set on Supabase (project blockblast / zxtwshhlicditrvqafzo):
#   supabase secrets set UPSTASH_REDIS_REST_URL=... UPSTASH_REDIS_REST_TOKEN=...
# Local copy below is optional reference only (gitignored .env). Never commit tokens.
# When unset, submit-run rate-limit degrades open (allows submit; response.rateLimit.degraded=true).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

